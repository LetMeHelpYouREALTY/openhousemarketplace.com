{
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "redirects": [
    {
      "source": "/index",
      "destination": "https://www.openhousemarketplace.com/",
      "permanent": true
    },
    {
      "source": "/index/",
      "destination": "https://www.openhousemarketplace.com/",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "https://www.openhousemarketplace.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "openhousemarketplace.com" }],
      "destination": "https://www.openhousemarketplace.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://www.openhousemarketplace.com",
    "SKIP_ENV_VALIDATION": "true"
  }
}
