# Public site origin (no trailing slash). Optional; falls back to NEXT_PUBLIC_APP_URL then default.
NEXT_PUBLIC_SITE_URL=https://www.openhousemarketplace.com

# Anthropic (server-only) — for local dev. On Vercel, use project env or team/shared
# "global" env; no duplicate entry needed if the key is already there.
# ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=

# Already used in Vercel config / app — sync with deployment
# NEXT_PUBLIC_APP_URL=
# Google Search Console — HTML tag verification (Settings → Ownership → HTML tag in GSC)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
# GBP profile URL for schema sameAs and review links (defaults to share link in config/gbp.ts)
# NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=https://share.google/Jgb4vGEoabNywBkJW
# Optional: real GBP star rating for JSON-LD (omit if unknown)
# NEXT_PUBLIC_GBP_RATING=4.9
# NEXT_PUBLIC_GBP_REVIEW_COUNT=127

# Resend (optional): contact form + open house sign-in notifications
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@openhousemarketplace.com
# RESEND_NOTIFY_EMAIL=jan@openhousemarketplace.com

# Maintenance: consumers see 503 page; Googlebot/Bingbot still crawl (SEO).
# NEXT_PUBLIC_SITE_MAINTENANCE_MODE=true
# NEXT_PUBLIC_SITE_MAINTENANCE_MESSAGE=Custom message (optional)
# Banner only (no 503 block): NEXT_PUBLIC_SITE_MAINTENANCE_BANNER_ONLY=true

# Site map iframe: defaults to OpenStreetMap (maps.google.com output=embed is deprecated/404).
# Optional: paste a valid iframe src from Google Maps → Share → Embed a map
# NEXT_PUBLIC_GOOGLE_MY_MAPS_EMBED_URL=
# Optional: use Google Maps Embed API (enable "Maps Embed API" in Cloud Console + HTTP referrer)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_USE_EMBED_API=true

# Optional: Google Maps Platform Commutes embed URL (default in lib/google-maps-commutes.ts)
# NEXT_PUBLIC_GOOGLE_MAPS_COMMUTES_EMBED_URL=

# Optional: Neighborhood Discovery embed URL (default in lib/google-maps-neighborhood-discovery.ts)
# NEXT_PUBLIC_GOOGLE_MAPS_NEIGHBORHOOD_DISCOVERY_EMBED_URL=

# Facebook / Meta — optional; enables Meta Pixel + fb:app_id when set (see config/facebook.ts, components/FacebookPixel.tsx)
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Scheduling / leads: Calendly is primary (no Follow Up Boss key required for normal operation).
# Optional legacy CRM hook — only if you enable server sync (see lib/followupboss-service.ts).
# FOLLOWUPBOSS_API_KEY=
# FOLLOWUPBOSS_BASE_URL=
